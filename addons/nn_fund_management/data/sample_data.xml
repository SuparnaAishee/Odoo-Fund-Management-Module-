<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Seed a small, realistic scenario (account, projects, a confirmed
         deposit, approved allocations and a partial bill) so the dashboard
         shows non-zero balances on a fresh deployment. The method is
         idempotent (skips once any fund account exists) and self-guarded, so
         it is safe to run on both install and upgrade. -->
    <function model="nn.fund.account" name="_seed_demo_data"/>
</odoo>
