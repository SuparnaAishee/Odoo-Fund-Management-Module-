<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="seq_incoming_fund" model="ir.sequence">
        <field name="name">Incoming Fund</field>
        <field name="code">nn.incoming.fund</field>
        <field name="prefix">INF/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_fund_allocation" model="ir.sequence">
        <field name="name">Fund Allocation</field>
        <field name="code">nn.fund.allocation</field>
        <field name="prefix">ALLOC/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_fund_requisition" model="ir.sequence">
        <field name="name">Fund Requisition</field>
        <field name="code">nn.fund.requisition</field>
        <field name="prefix">REQ/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_fund_bill" model="ir.sequence">
        <field name="name">Fund Bill</field>
        <field name="code">nn.fund.bill</field>
        <field name="prefix">BILL/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="seq_fund_transfer" model="ir.sequence">
        <field name="name">Fund Transfer</field>
        <field name="code">nn.fund.transfer</field>
        <field name="prefix">TRF/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>
