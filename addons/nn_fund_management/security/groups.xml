<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_fund" model="ir.module.category">
        <field name="name">Fund Management</field>
        <field name="sequence">15</field>
    </record>

    <!-- Operational hierarchy: Fund User < Finance User < Fund Administrator -->
    <record id="group_fund_user" model="res.groups">
        <field name="name">Fund User</field>
        <field name="category_id" ref="module_category_fund"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_finance_user" model="res.groups">
        <field name="name">Finance User</field>
        <field name="category_id" ref="module_category_fund"/>
        <field name="implied_ids" eval="[(4, ref('group_fund_user'))]"/>
    </record>

    <record id="group_fund_admin" model="res.groups">
        <field name="name">Fund Administrator</field>
        <field name="category_id" ref="module_category_fund"/>
        <field name="implied_ids" eval="[(4, ref('group_finance_user'))]"/>
    </record>

    <!-- Approval groups are orthogonal to the operational hierarchy: an approver
         is not necessarily a Finance user (security-matrix). -->
    <record id="group_gm_approver" model="res.groups">
        <field name="name">GM Approver</field>
        <field name="category_id" ref="module_category_fund"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_md_approver" model="res.groups">
        <field name="name">MD Approver</field>
        <field name="category_id" ref="module_category_fund"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- The admin user gets full fund-management rights out of the box. -->
    <record id="base.user_admin" model="res.users">
        <field name="groups_id" eval="[(4, ref('group_fund_admin')), (4, ref('group_gm_approver')), (4, ref('group_md_approver'))]"/>
    </record>
</odoo>
