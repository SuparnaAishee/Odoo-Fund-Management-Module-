<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_expense_head_tree" model="ir.ui.view">
        <field name="name">nn.expense.head.tree</field>
        <field name="model">nn.expense.head</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
                <field name="allocated" sum="Allocated"/>
                <field name="available" sum="Available"/>
                <field name="spent" sum="Spent"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="company_id" column_invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="view_expense_head_form" model="ir.ui.view">
        <field name="name">nn.expense.head.form</field>
        <field name="model">nn.expense.head</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_movements" type="object"
                                class="oe_stat_button" icon="fa-list">
                            <field name="movement_count" widget="statinfo" string="Movements"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. Office Rent"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group string="Balances (computed from the ledger)">
                            <field name="allocated"/>
                            <field name="available"/>
                            <field name="requisition_hold"/>
                            <field name="transfer_hold"/>
                            <field name="spent"/>
                            <field name="transfer_in"/>
                            <field name="transfer_out"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_expense_head" model="ir.actions.act_window">
        <field name="name">Expense Heads</field>
        <field name="res_model">nn.expense.head</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
