<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fund_requisition_tree" model="ir.ui.view">
        <field name="name">nn.fund.requisition.tree</field>
        <field name="model">nn.fund.requisition</field>
        <field name="arch" type="xml">
            <tree decoration-success="state == 'approved'"
                  decoration-danger="state == 'rejected'"
                  decoration-muted="state in ('draft','cancelled','closed')">
                <field name="name"/>
                <field name="request_date"/>
                <field name="target_name"/>
                <field name="amount" sum="Total"/>
                <field name="remaining_billable" sum="Remaining Billable"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="requested_by"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>

    <record id="view_fund_requisition_form" model="ir.ui.view">
        <field name="name">nn.fund.requisition.form</field>
        <field name="model">nn.fund.requisition</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" type="object" string="Submit"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve" type="object" string="Approve"
                            class="oe_highlight" invisible="state not in ('submitted','gm_approval','md_approval')"/>
                    <button name="action_reject" type="object" string="Reject"
                            invisible="state not in ('submitted','gm_approval','md_approval')"/>
                    <button name="action_close" type="object" string="Close"
                            invisible="state != 'approved'"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state in ('approved','rejected','cancelled','closed')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,gm_approval,approved"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_bills" type="object"
                                class="oe_stat_button" icon="fa-money">
                            <field name="bill_count" widget="statinfo" string="Bills"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="project_id" readonly="state != 'draft'" options="{'no_create': True}"/>
                            <field name="expense_head_id" readonly="state != 'draft'" options="{'no_create': True}"/>
                            <field name="amount" readonly="state != 'draft'"/>
                            <field name="remaining_billable"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="request_date" readonly="state != 'draft'"/>
                            <field name="required_date" readonly="state != 'draft'"/>
                            <field name="requested_by" readonly="1"/>
                            <field name="current_level" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="purpose" readonly="state != 'draft'"/>
                        <field name="attachment_ids" widget="many2many_binary" readonly="state != 'draft'"/>
                    </group>
                    <notebook>
                        <page string="Approval History">
                            <field name="approval_line_ids" readonly="1">
                                <tree>
                                    <field name="decision_date"/>
                                    <field name="level"/>
                                    <field name="approver_id"/>
                                    <field name="result" widget="badge"/>
                                    <field name="comment"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_fund_requisition_kanban" model="ir.ui.view">
        <field name="name">nn.fund.requisition.kanban</field>
        <field name="model">nn.fund.requisition</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column o_nn_fund_kanban">
                <field name="state"/>
                <field name="amount"/>
                <field name="remaining_billable"/>
                <field name="currency_id"/>
                <field name="target_name"/>
                <field name="requested_by"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click oe_kanban_card">
                            <div t-if="record.state.raw_value == 'approved'" class="bg-success" style="height:4px;"/>
                            <div t-elif="record.state.raw_value == 'rejected'" class="bg-danger" style="height:4px;"/>
                            <div t-elif="['submitted','gm_approval','md_approval'].includes(record.state.raw_value)" class="bg-warning" style="height:4px;"/>
                            <div t-else="" class="bg-secondary" style="height:4px;"/>
                            <div class="p-2">
                                <div class="d-flex justify-content-between align-items-start">
                                    <strong><field name="name"/></strong>
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'approved'"
                                           decoration-danger="state == 'rejected'"
                                           decoration-warning="state in ('submitted','gm_approval','md_approval')"
                                           decoration-muted="state in ('draft','cancelled','closed')"/>
                                </div>
                                <div class="text-muted"><field name="target_name"/></div>
                                <h4 class="mt-2 mb-1"><field name="amount" widget="monetary"/></h4>
                                <div t-if="record.state.raw_value == 'approved'" class="text-muted">
                                    <i class="fa fa-hand-holding-usd me-1" title="Remaining billable"/>Billable: <field name="remaining_billable" widget="monetary"/>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mt-2">
                                    <small class="text-muted"><i class="fa fa-user me-1" title="Requested by"/><field name="requested_by"/></small>
                                    <div>
                                        <button name="action_submit" type="object" class="btn btn-sm btn-primary"
                                                t-if="record.state.raw_value == 'draft'">Submit</button>
                                        <button name="action_approve" type="object" class="btn btn-sm btn-success"
                                                t-if="['submitted','gm_approval','md_approval'].includes(record.state.raw_value)">Approve</button>
                                        <button name="action_reject" type="object" class="btn btn-sm btn-outline-danger ms-1"
                                                t-if="['submitted','gm_approval','md_approval'].includes(record.state.raw_value)">Reject</button>
                                        <button name="action_close" type="object" class="btn btn-sm btn-outline-secondary"
                                                t-if="record.state.raw_value == 'approved'">Close</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_fund_requisition_search" model="ir.ui.view">
        <field name="name">nn.fund.requisition.search</field>
        <field name="model">nn.fund.requisition</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="target_name"/>
                <field name="requested_by"/>
                <filter name="my_requests" string="My Requests" domain="[('requested_by', '=', uid)]"/>
                <separator/>
                <filter name="draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="pending" string="Pending Approval"
                        domain="[('state', 'in', ('submitted', 'gm_approval', 'md_approval'))]"/>
                <filter name="approved" string="Approved" domain="[('state', '=', 'approved')]"/>
                <filter name="closed" string="Closed" domain="[('state', '=', 'closed')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_requested_by" string="Requested By" context="{'group_by': 'requested_by'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_fund_requisition" model="ir.actions.act_window">
        <field name="name">Fund Requisitions</field>
        <field name="res_model">nn.fund.requisition</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>
</odoo>
