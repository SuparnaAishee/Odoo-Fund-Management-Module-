<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fund_transfer_tree" model="ir.ui.view">
        <field name="name">nn.fund.transfer.tree</field>
        <field name="model">nn.fund.transfer</field>
        <field name="arch" type="xml">
            <tree decoration-success="state == 'approved'"
                  decoration-danger="state == 'rejected'"
                  decoration-muted="state in ('draft','cancelled')">
                <field name="name"/>
                <field name="request_date"/>
                <field name="source_name"/>
                <field name="dest_name"/>
                <field name="amount" sum="Total"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="requested_by"/>
                <field name="state" widget="badge"/>
            </tree>
        </field>
    </record>

    <record id="view_fund_transfer_form" model="ir.ui.view">
        <field name="name">nn.fund.transfer.form</field>
        <field name="model">nn.fund.transfer</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" type="object" string="Submit"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve" type="object" string="Approve"
                            class="oe_highlight" invisible="state not in ('submitted','gm_approval','md_approval')"/>
                    <button name="action_reject" type="object" string="Reject"
                            invisible="state not in ('submitted','gm_approval','md_approval')"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state in ('approved','rejected','cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,gm_approval,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="From">
                            <field name="src_project_id" readonly="state != 'draft'" options="{'no_create': True}"/>
                            <field name="src_head_id" readonly="state != 'draft'" options="{'no_create': True}"/>
                        </group>
                        <group string="To">
                            <field name="dest_project_id" readonly="state != 'draft'" options="{'no_create': True}"/>
                            <field name="dest_head_id" readonly="state != 'draft'" options="{'no_create': True}"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="amount" readonly="state != 'draft'"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="request_date" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="requested_by" readonly="1"/>
                            <field name="current_level" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="reason" readonly="state != 'draft'"/>
                    </group>
                    <notebook>
                        <page string="Approval History">
                            <field name="approval_line_ids" readonly="1">
                                <tree>
                                    <field name="decision_date"/>
                                    <field name="level"/>
                                    <field name="approver_id"/>
                                    <field name="result" widget="badge"/>
                                    <field name="comment"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_fund_transfer" model="ir.actions.act_window">
        <field name="name">Fund Transfers</field>
        <field name="res_model">nn.fund.transfer</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
