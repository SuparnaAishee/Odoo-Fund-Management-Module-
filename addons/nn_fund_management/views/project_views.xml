<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_project_tree" model="ir.ui.view">
        <field name="name">nn.project.tree</field>
        <field name="model">nn.project</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
                <field name="company_id" column_invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="view_project_form" model="ir.ui.view">
        <field name="name">nn.project.form</field>
        <field name="model">nn.project</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Project name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id"/>
                            <field name="active" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_project" model="ir.actions.act_window">
        <field name="name">Projects</field>
        <field name="res_model">nn.project</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
