<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fund_account_tree" model="ir.ui.view">
        <field name="name">nn.fund.account.tree</field>
        <field name="model">nn.fund.account</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="code"/>
                <field name="account_type"/>
                <field name="received" sum="Total Received"/>
                <field name="unassigned" sum="Unassigned"/>
                <field name="on_hold" sum="On Hold"/>
                <field name="assigned" sum="Assigned"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="company_id" column_invisible="1"/>
            </tree>
        </field>
    </record>

    <record id="view_fund_account_form" model="ir.ui.view">
        <field name="name">nn.fund.account.form</field>
        <field name="model">nn.fund.account</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. NN Operations - City Bank"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="account_type"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id"/>
                        </group>
                    </group>
                    <group string="Balances (computed from the ledger)">
                        <group>
                            <field name="received"/>
                            <field name="unassigned"/>
                        </group>
                        <group>
                            <field name="on_hold"/>
                            <field name="assigned"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Ledger Movements">
                            <field name="movement_ids" readonly="1">
                                <tree>
                                    <field name="date"/>
                                    <field name="move_type"/>
                                    <field name="reference"/>
                                    <field name="amount"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fund_account" model="ir.actions.act_window">
        <field name="name">Fund Accounts</field>
        <field name="res_model">nn.fund.account</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
