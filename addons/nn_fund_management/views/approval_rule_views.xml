<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_approval_rule_tree" model="ir.ui.view">
        <field name="name">nn.approval.rule.tree</field>
        <field name="model">nn.approval.rule</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="model_name"/>
                <field name="min_amount"/>
                <field name="max_amount"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <record id="view_approval_rule_form" model="ir.ui.view">
        <field name="name">nn.approval.rule.form</field>
        <field name="model">nn.approval.rule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Above 200,000"/></h1>
                    </div>
                    <group>
                        <group string="Applies When">
                            <field name="model_name"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="min_amount"/>
                            <field name="max_amount"/>
                        </group>
                        <group string="Settings">
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <separator string="Approval Levels (in order)"/>
                    <field name="line_ids">
                        <tree editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="level"/>
                        </tree>
                    </field>
                    <p class="text-muted">
                        The request is approved through these levels in order. At most three levels.
                    </p>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_approval_rule" model="ir.actions.act_window">
        <field name="name">Approval Rules</field>
        <field name="res_model">nn.approval.rule</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create an approval rule</p>
            <p>Route requests through different approval chains based on amount, type or company.
               With no rule, requests use the default GM → MD chain.</p>
        </field>
    </record>
</odoo>
